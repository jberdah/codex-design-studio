{
  "title": "Acme Brand",
  "lang": "en",
  "cssVariables": {
    "--brand-primary": "#123456",
    "--radius-card": "16px",
    "--space-md": "24px"
  },
  "elements": [
    {
      "tag": "header", "role": "banner", "text": "Acme", "path": "body > header",
      "colors": ["rgb(18, 52, 86)", "rgb(255, 255, 255)"], "fontFamily": "Inter, sans-serif",
      "fontSize": "16px", "fontWeight": "600", "lineHeight": "24px", "letterSpacing": "0px",
      "margin": "0px", "padding": "24px", "gap": "16px", "borderRadius": "0px", "display": "flex",
      "gridTemplateColumns": "none", "width": 1200, "height": 72, "assetUrls": ["https://cdn.example.com/logo.svg"]
    },
    {
      "tag": "button", "role": "", "text": "Start", "path": "body > main > button:nth-of-type(1)",
      "colors": ["rgb(18, 52, 86)", "rgb(255, 255, 255)"], "fontFamily": "Inter, sans-serif",
      "fontSize": "16px", "fontWeight": "600", "lineHeight": "24px", "letterSpacing": "0px",
      "margin": "0px", "padding": "12px 24px", "gap": "8px", "borderRadius": "16px", "display": "flex",
      "gridTemplateColumns": "none", "width": 140, "height": 48, "assetUrls": []
    },
    {
      "tag": "button", "role": "", "text": "Learn", "path": "body > main > button:nth-of-type(2)",
      "colors": ["rgb(18, 52, 86)", "rgb(255, 255, 255)"], "fontFamily": "Inter, sans-serif",
      "fontSize": "16px", "fontWeight": "600", "lineHeight": "24px", "letterSpacing": "0px",
      "margin": "0px", "padding": "12px 24px", "gap": "8px", "borderRadius": "16px", "display": "flex",
      "gridTemplateColumns": "none", "width": 140, "height": 48, "assetUrls": []
    }
  ],
  "logos": [{ "path": "body > header > img", "url": "https://cdn.example.com/logo.svg", "text": "Acme logo", "width": 120, "height": 32 }]
}
