{
  "name": "codex-design-studio",
  "productName": "Codex Design Studio",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.cjs",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:agent": "node scripts/test-agent.mjs",
    "preflight": "node scripts/preflight.mjs",
    "desktop:dev": "concurrently -k \"npm run dev -- --hostname 127.0.0.1\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "desktop:icon": "sh desktop/build-icon.sh",
    "desktop:prepare": "npm run desktop:icon && node desktop/prepare-runtime.mjs",
    "desktop:package": "npm run build && npm run desktop:prepare && electron-forge package",
    "desktop:make": "npm run build && npm run desktop:prepare && electron-forge make && sh desktop/make-dmg.sh",
    "check": "npm run typecheck && npm run test && npm run build",
    "check:all": "npm run check && npm run test:e2e"
  },
  "dependencies": {
    "@openai/codex": "0.144.5",
    "jszip": "^3.10.1",
    "next": "^16.2.10",
    "pixelmatch": "^7.1.0",
    "playwright": "1.55.1",
    "pngjs": "^7.0.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@playwright/test": "1.55",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.7",
    "concurrently": "^9.2.1",
    "electron": "^43.1.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7",
    "wait-on": "^8.0.5"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
