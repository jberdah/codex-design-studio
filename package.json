{
  "name": "codex-design-studio",
  "productName": "Codex Design Studio",
  "version": "0.1.0",
  "description": "Local-first AI creative workspace powered by GPT-5.6 and Codex.",
  "author": "jberdah",
  "private": true,
  "main": "desktop/main.cjs",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:electron": "playwright test --config playwright.electron.config.ts",
    "test:electron:packaged": "node scripts/test-packaged-electron.mjs",
    "test:runtime:packaged": "node scripts/verify-packaged-runtime.mjs",
    "test:agent": "node scripts/test-agent.mjs",
    "media:devpost": "node scripts/generate-devpost-media.mjs",
    "preflight": "node scripts/preflight.mjs",
    "desktop:dev": "electron .",
    "desktop:icon": "node desktop/build-icons.mjs",
    "desktop:prepare": "npm run desktop:icon && node desktop/prepare-runtime.mjs",
    "desktop:package": "node desktop/build-desktop.mjs package",
    "desktop:make": "node desktop/build-desktop.mjs make",
    "check": "npm run typecheck && npm run test && npm run build",
    "check:all": "npm run check && npm run test:e2e"
  },
  "dependencies": {
    "@openai/codex": "0.144.5",
    "electron-squirrel-startup": "^1.0.1",
    "jszip": "^3.10.1",
    "next": "^16.2.10",
    "pixelmatch": "^7.1.0",
    "playwright": "1.55.1",
    "pngjs": "^7.0.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@playwright/test": "1.55",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.7",
    "concurrently": "^9.2.1",
    "electron": "^43.1.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7",
    "wait-on": "^8.0.5"
  },
  "overrides": {
    "postcss": "8.5.10",
    "tar": "7.5.16",
    "tmp": "0.2.7"
  }
}
